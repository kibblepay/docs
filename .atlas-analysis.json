  "keyFeatures": [
    "Instant USDC payment links via CLI or API",
    "PDF invoice generation with email delivery",
    "Real-time on-chain payment detection (Alchemy webhooks)",
    "Kibble-provisioned or bring-your-own wallet support",
    "Embeddable checkout iframe and JS widget",
    "Merchant portal with payment tracking",
    "Signed webhook notifications for payment events",
    "Non-interactive CLI modes for automation and agent pipelines"
  ],
  "publicApiSurface": [
    "POST /api/links — create a payment link",
    "GET /api/links/[slug] — get payment link details",
    "GET /api/payments/status/[slug] — poll payment status",
    "GET /api/merchant/[slug] — merchant dashboard data",
    "POST /api/invoices — create invoice with line items",
    "GET /api/invoices/[id] — full invoice JSON",
    "GET /api/invoices/[id]/status — lightweight status check",
    "POST /api/invoices/[id]/send — re-send vendor email",
    "GET /api/invoices/[id]/pdf — stream invoice PDF",
    "npx create-kibble — interactive CLI",
    "create-kibble --yes — non-interactive payment link from env vars",
    "create-kibble --stdin — pipe JSON invoice payload",
    "create-kibble --stdin --dry-run — validate without hitting API"
  ]
